                    colorSpace = "sRGB"
                )
                float inputs:emissive_intensity
                asset inputs:emissive_mask_texture (
                    colorSpace = "raw"
                )
                bool inputs:enable_emission
                bool inputs:enable_opacity
                bool inputs:enable_opacity_texture
                bool inputs:enable_ORM_texture
                bool inputs:flip_tangent_u
                bool inputs:flip_tangent_v
                float inputs:geometry_normal_roughness_strength
                float inputs:metallic_constant
                asset inputs:metallic_texture (
                    colorSpace = "raw"
                )
                float inputs:metallic_texture_influence
                asset inputs:normalmap_texture (
                    colorSpace = "raw"
                )
                float inputs:opacity_constant
                int inputs:opacity_mode
                asset inputs:opacity_texture (
                    colorSpace = "raw"
                )
                float inputs:opacity_threshold
                asset inputs:ORM_texture (
                    colorSpace = "raw"
                )
                bool inputs:project_uvw
                float inputs:reflection_roughness_constant
                float inputs:reflection_roughness_texture_influence
                asset inputs:reflectionroughness_texture (
                    colorSpace = "raw"
                )
                float inputs:specular_level
                float inputs:texture_rotate
                float2 inputs:texture_scale
                float2 inputs:texture_translate
                int inputs:uv_space_index
                bool inputs:world_or_object
                token outputs:out
            }
        }

        def Scope "_mdl_residency"
        {
            def Scope "OmniPBR"
            {
                def Material "Material"
                {
                    token outputs:displacement.connect = </World/Looks/_mdl_residency/OmniPBR/Material/Shader.outputs:out>
                    token outputs:mdl:displacement.connect = </World/Looks/_mdl_residency/OmniPBR/Material/Shader.outputs:out>
                    token outputs:mdl:surface.connect = </World/Looks/_mdl_residency/OmniPBR/Material/Shader.outputs:out>
                    token outputs:mdl:volume.connect = </World/Looks/_mdl_residency/OmniPBR/Material/Shader.outputs:out>
                    token outputs:surface.connect = </World/Looks/_mdl_residency/OmniPBR/Material/Shader.outputs:out>
                    token outputs:volume.connect = </World/Looks/_mdl_residency/OmniPBR/Material/Shader.outputs:out>

                    def Shader "Shader"
                    {
                        uniform token info:id = "mdlMaterial"
                        token info:implementationSource = "sourceAsset"
                        asset info:mdl:sourceAsset = @OmniPBR.mdl@
                        token info:mdl:sourceAsset:subIdentifier = "OmniPBR"
                        token outputs:out
                    }
                }
            }
        }
    }

    def "EnvironmentVariants"
    {
        def Xform "ClearSkyEnvironment" (
            customData = {
                dictionary kbpbr = {
                    bool localized_environment = 1
                }
            }
        )
        {
            def Xform "Environment"
            {
                custom string date = "2021-06-21"
                custom double location:latitude = 40.4168
                custom double location:longitude = -3.7038
                custom double location:north_orientation = 0
                custom float time:current = 14.5
                custom float weather:cloud_coverage = 0
                custom bool weather:cumulus_enabled = 0
                custom float weather:haze = 0.08

                def Xform "sky" (
                    prepend references = @./clearsky_assets/Assets/Skies/Dynamic/ClearSky.usd@
                )
                {
                    float3 xformOp:rotateZYX = (0, 0, 0)

                    over "AxisNorth"
                    {
                        double3 xformOp:rotateZYX = (0, 0, 0)

                        over "AxisLatitude"
                        {
                            double3 xformOp:rotateZYX = (0, 0, 40.4168)

                            over "AxisSHA"
                            {
                                double3 xformOp:rotateZYX = (142.84346559996118, 0, 0)

                                over "AxisDeclination"
                                {
                                    double3 xformOp:rotateZYX = (0, 0, 7.999834338981633)

                                    over "DistantLight"
                                    {
                                        color3f inputs:color = (1, 0.98, 0.95)
                                        float inputs:intensity = 5000
                                    }
                                }
                            }
                        }

                        over "AxisAzimuth"
                        {
                            double3 xformOp:rotateZYX = (0, 124.15125931235416, 0)

                            over "AxisElevation"
                            {
                                double3 xformOp:rotateZYX = (0, 0, 43.718102266652515)
                            }
                        }
                    }

                    over "DomeLight"
                    {
                        float3 xformOp:rotateZYX = (270, 0, 0)
                    }

                    over "Looks"
                    {
                        over "SkyMaterial"
                        {
                            over "Shader"
                            {
                                float inputs:Azimuth = 124.15126
                                float inputs:DayOfYear = 100
                                float inputs:Declination = 7.9998345
                                float inputs:Elevation = 43.7181
                                float inputs:Latitude = 51.426
                                float inputs:Longitude = -0.985
                                float inputs:NorthOrientation = 0
                                float inputs:SHA = 37.156536
                                float inputs:TimeOfDay = 6.93
                            }
                        }
                    }
                }
            }
        }
    }
