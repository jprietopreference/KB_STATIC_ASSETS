    def Xform "Looks"
    {
        def Material "CameraSoftboxCard"
        {
            token outputs:surface.connect = </World/Looks/CameraSoftboxCard/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (1, 1, 1)
                color3f inputs:emissiveColor = (28.8, 28.368, 27.648)
                float inputs:metallic = 0
                float inputs:opacity = 1
                float inputs:roughness = 0
                token outputs:surface
            }
        }

        def Material "GroundCheckerLight"
        {
            token outputs:surface.connect = </World/Looks/GroundCheckerLight/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.82, 0.82, 0.82)
                float inputs:metallic = 0
                float inputs:opacity = 1
                float inputs:roughness = 0.22
                token outputs:surface
            }
        }

        def Material "GroundCheckerDark"
        {
            token outputs:surface.connect = </World/Looks/GroundCheckerDark/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.2, 0.2, 0.2)
                float inputs:metallic = 0
                float inputs:opacity = 1
                float inputs:roughness = 0.22
                token outputs:surface
            }
        }

        def Material "ActiveMaterial"
        {
            token outputs:displacement.connect = </World/Looks/ActiveMaterial/Shader.outputs:out>
            token outputs:mdl:displacement.connect = </World/Looks/ActiveMaterial/Shader.outputs:out>
            token outputs:mdl:surface.connect = </World/Looks/ActiveMaterial/Shader.outputs:out>
            token outputs:mdl:volume.connect = </World/Looks/ActiveMaterial/Shader.outputs:out>
            token outputs:surface.connect = </World/Looks/ActiveMaterial/Shader.outputs:out>
            token outputs:volume.connect = </World/Looks/ActiveMaterial/Shader.outputs:out>

            def Shader "Shader"
            {
                uniform token info:id = "mdlMaterial"
                token info:implementationSource = "sourceAsset"
                asset info:mdl:sourceAsset = @OmniPBR.mdl@
                token info:mdl:sourceAsset:subIdentifier = "OmniPBR"
                float inputs:albedo_add
                float inputs:albedo_brightness
                float inputs:albedo_desaturation
                asset inputs:ao_texture (
                    colorSpace = "raw"
                )
                float inputs:ao_to_diffuse
                float inputs:bump_factor
                float inputs:detail_bump_factor
                asset inputs:detail_normalmap_texture (
                    colorSpace = "raw"
                )
                float inputs:detail_texture_rotate
                float2 inputs:detail_texture_scale
                float2 inputs:detail_texture_translate
                color3f inputs:diffuse_color_constant
